# Copy to .env and fill in. Only the provider key(s) you actually use are required.
# v0 runs locally on SQLite; no Postgres/n8n needed.

DATABASE_URL=sqlite:///./scw.db

# LLM provider keys (LiteLLM reads these from the environment)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Optional: OpenAI-compatible / local providers ---
# OpenAI-compatible endpoint (LM Studio, vLLM, Groq, Together, DeepSeek-direct, …):
#   set OPENAI_API_KEY above + this base URL, then use slug "openai/<model>" in a profile.
OPENAI_BASE_URL=
# Local Ollama (no key): use slug "ollama_chat/<model>" in a profile.
OLLAMA_BASE_URL=http://localhost:11434
